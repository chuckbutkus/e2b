{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "service", "probes"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "service": {
      "type": "object",
      "required": ["port", "targetPort"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "probes": {
      "type": "object",
      "required": ["type", "path", "readyPath"],
      "properties": {
        "type": { "type": "string", "enum": ["http", "tcp", "exec"] }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automountToken": { "type": "boolean" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" }
      },
      "if": { "properties": { "enabled": { "const": true } } },
      "then": {
        "required": ["host"],
        "properties": {
          "host": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string" },
        "createGateway": { "type": "boolean" },
        "parentRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" },
            "sectionName": { "type": "string" }
          }
        },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "secretName": { "type": "string" },
            "issuerName": { "type": "string" },
            "issuerKind": { "type": "string", "enum": ["ClusterIssuer", "Issuer"] }
          }
        }
      },
      "if": { "properties": { "enabled": { "const": true } } },
      "then": {
        "required": ["host"],
        "properties": {
          "host": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
